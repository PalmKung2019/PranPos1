
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores application-specific profile information for users authenticated via Firebase, including their role and contact details.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "firebaseAuthUid": {
          "type": "string",
          "description": "Unique identifier from Firebase Authentication, linking this profile to the external authentication system."
        },
        "firstName": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "email": {
          "type": "string",
          "description": "The user's primary contact email address.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "deliveryAddress": {
          "type": "string",
          "description": "The user's saved delivery address."
        },
        "role": {
          "type": "string",
          "description": "The role of the user (e.g., 'Manager', 'Staff', 'Customer')."
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "firebaseAuthUid",
        "firstName",
        "lastName",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a menu item available in the Savor Happiness Cafe.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the menu item."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "price": {
          "type": "number",
          "description": "The selling price of the product."
        },
        "category": {
          "type": "string",
          "description": "The category the product belongs to."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL to the image of the product.",
          "format": "uri"
        },
        "isAvailable": {
          "type": "boolean",
          "description": "Availability flag."
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "category"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a customer's purchase order.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order entity."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to the UserProfile ID of the customer who placed the order."
        },
        "totalAmount": {
          "type": "number",
          "description": "Total order amount including delivery fee."
        },
        "deliveryFee": {
          "type": "number",
          "description": "The fee charged for delivery."
        },
        "deliveryAddress": {
          "type": "string",
          "description": "The address where the order should be delivered."
        },
        "status": {
          "type": "string",
          "description": "Order status (Pending, Preparing, Delivering, Completed)."
        },
        "paymentMethod": {
          "type": "string",
          "description": "Method used for payment (Cash, PromptPay)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "totalAmount",
        "status",
        "createdAt",
        "deliveryAddress"
      ]
    },
    "ChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatMessage",
      "type": "object",
      "description": "A single chat message in a conversation between a customer and staff.",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["Staff", "Customer", "Manager"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderRole", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "phone"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{firebaseAuthUid}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/roles_manager/{firebaseAuthUid}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "DBAC for Managers."
        }
      },
      {
        "path": "/roles_staff/{firebaseAuthUid}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "DBAC for Staff."
        }
      },
      {
        "path": "/roles_customer/{firebaseAuthUid}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "DBAC for Customers/Members."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Menu items."
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Customer orders."
        }
      },
      {
        "path": "/chats/{customerId}/messages/{messageId}",
        "definition": {
          "entityName": "ChatMessage",
          "schema": {
            "$ref": "#/backend/entities/ChatMessage"
          },
          "description": "Chat messages between a specific customer and staff members."
        }
      }
    ]
  }
}
